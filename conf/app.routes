# microservice specific routes

POST  /services/:service/features/:feature                     uk.gov.hmrc.ratelimitedallowlist.controllers.AllowListController.checkAllowList(service: Service, feature: Feature)

GET   /services                                                uk.gov.hmrc.ratelimitedallowlist.controllers.AllowListAdminController.getServices()
POST  /services/:service/allow-lists                           uk.gov.hmrc.ratelimitedallowlist.controllers.AllowListAdminController.create(service: Service)
GET   /services/:service/features                              uk.gov.hmrc.ratelimitedallowlist.controllers.AllowListAdminController.getFeatures(service: Service)
GET   /services/:service/features/:feature/metadata            uk.gov.hmrc.ratelimitedallowlist.controllers.AllowListAdminController.get(service: Service, feature: Feature)
PATCH /services/:service/features/:feature/metadata            uk.gov.hmrc.ratelimitedallowlist.controllers.AllowListAdminController.patch(service: Service, feature: Feature)
POST  /services/:service/features/:feature/metadata/tokens     uk.gov.hmrc.ratelimitedallowlist.controllers.AllowListAdminController.addTokens(service: Service, feature: Feature)
GET   /services/:service/features/:feature/report              uk.gov.hmrc.ratelimitedallowlist.controllers.AllowListAdminController.getAllowListReport(service: Service, feature: Feature, queryParams: AllowListReportQueryParams)
